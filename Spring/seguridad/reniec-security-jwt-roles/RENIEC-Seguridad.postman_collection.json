        {
          "name": "2) POST login (alumno)  -> 200 + guarda token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status code es 200\", function () { pm.response.to.have.status(200); });",
                  "var json = pm.response.json();",
                  "pm.test(\"Recibe un token\", function () { pm.expect(json.token).to.be.a(\"string\"); });",
                  "// Guardamos el token para las siguientes peticiones",
                  "pm.collectionVariables.set(\"tokenJwt\", json.token);",
                  "console.log(\"tokenJwt guardado\");"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "auth": {
              "type": "noauth"
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usuario\": \"{{userAlumno}}\",\n  \"clave\": \"{{passAlumno}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl2}}/api/v1/auth/login",
              "host": [
                "{{baseUrl2}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Valida usuario/clave y devuelve el token. Un test script lo guarda en {{tokenJwt}}."
          },
          "response": []
        },
